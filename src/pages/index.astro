---
import MainLayout from '../layouts/MainLayout.astro';
import {
  siteConfig,
  professionalSummary,
  professionalSummaryEn,
  impactHighlights,
  impactHighlightsEn
} from '../config/site';
import { getCollection } from 'astro:content';

const featuredProjects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 2);

const stackGrid = [
  {
    label: 'PYTHON',
    detailEs: 'Automatizacion, logica de negocio y servicios backend.',
    detailEn: 'Automation, business logic, and backend services.'
  },
  {
    label: 'C# / .NET',
    detailEs: 'Sistemas transaccionales y reglas operativas.',
    detailEn: 'Transactional systems and operational rules.'
  },
  {
    label: 'JAVASCRIPT',
    detailEs: 'Interfaces web con foco en claridad y mantenimiento.',
    detailEn: 'Web interfaces focused on clarity and maintainability.'
  },
  {
    label: 'SQL / DATA',
    detailEs: 'Modelado relacional, consultas y consistencia de datos.',
    detailEn: 'Relational modeling, queries, and data consistency.'
  },
  {
    label: 'WEB APPS',
    detailEs: 'Productos conectados a procesos reales y usuarios reales.',
    detailEn: 'Products connected to real workflows and users.'
  },
  {
    label: 'TEAM FLOW',
    detailEs: 'GitHub, colaboracion y entrega ordenada.',
    detailEn: 'GitHub, collaboration, and organized delivery.'
  }
] as const;

const proofMetrics = [
  { value: '02', labelEs: 'proyectos destacados', labelEn: 'featured systems' },
  { value: '06', labelEs: 'capacidades nucleares', labelEn: 'core capabilities' },
  { value: '100%', labelEs: 'enfoque practico', labelEn: 'practical mindset' },
  { value: '24/7', labelEs: 'mentalidad de soporte', labelEn: 'support mindset' }
] as const;

const operatingModes = [
  {
    id: '01',
    titleEs: 'Arquitectura legible',
    titleEn: 'Readable architecture',
    copyEs: impactHighlights[1],
    copyEn: impactHighlightsEn[1]
  },
  {
    id: '02',
    titleEs: 'Colaboracion estable',
    titleEn: 'Stable collaboration',
    copyEs: impactHighlights[0],
    copyEn: impactHighlightsEn[0]
  },
  {
    id: '03',
    titleEs: 'Ejecucion confiable',
    titleEn: 'Reliable execution',
    copyEs: impactHighlights[2],
    copyEn: impactHighlightsEn[2]
  }
] as const;
---

<MainLayout
  title="Software Developer Portfolio"
  description={siteConfig.description}
  canonicalPath="/"
>
  <section class="hero-section pt-8 sm:pt-12">
    <div class="container-shell">
      <div class="hero-shell">
        <div class="hero-grid panel cut-corner rounded-[2rem] p-7 sm:p-10">
          <div data-motion="hero-copy" class="hero-copy">
            <p class="accent-pill px-4 py-2">
              <span class="lang-es">sistema online // estado: disponible</span>
              <span class="lang-en">system online // status: available</span>
            </p>

            <h1 data-motion="hero-title" class="display-title name-lockup mt-8 text-balance text-5xl font-semibold uppercase leading-[0.92] sm:text-7xl lg:text-[5.2rem]">
              <span class="block text-[color:var(--color-text-strong)]">Juan Pablo</span>
              <span class="hero-accent block">Pinilla</span>
            </h1>

            <p class="mt-6 max-w-2xl text-base leading-8 text-[color:var(--color-text-soft)] sm:text-lg">
              <span class="lang-es">{professionalSummary}</span>
              <span class="lang-en">{professionalSummaryEn}</span>
            </p>

            <div class="chip-list mt-6">
              <span class="chip-item">
                <span class="lang-es">{siteConfig.roleEs}</span>
                <span class="lang-en">{siteConfig.roleEn}</span>
              </span>
              <span class="chip-item">
                <span class="lang-es">{siteConfig.location}</span>
                <span class="lang-en">{siteConfig.locationEn}</span>
              </span>
            </div>

            <div data-motion-stagger class="hero-actions mt-8">
              <a data-motion-hover href="/projects" class="btn-primary">
                <span class="lang-es">Explorar trabajo</span>
                <span class="lang-en">Explore work</span>
              </a>
              <a data-motion-hover href={siteConfig.linkedin} target="_blank" rel="noreferrer" class="btn-secondary">
                LinkedIn
              </a>
              <a data-motion-hover href="/contact" class="btn-secondary">
                <span class="lang-es">Iniciar contacto</span>
                <span class="lang-en">Start contact</span>
              </a>
            </div>
          </div>

          <aside class="hero-media">
            <figure data-motion="hero-media" class="hero-photo panel rounded-[1.8rem] p-4">
              <div class="hero-photo__frame">
                <img
                  src={siteConfig.profileImage}
                  alt={siteConfig.profileImageAlt}
                  loading="eager"
                  class="hero-photo__image"
                />
                <div class="hero-photo__wash"></div>
              </div>

              <figcaption class="hero-photo__caption">
                <div>
                  <p class="eyebrow">profile portrait</p>
                  <p class="mt-3 text-lg font-semibold text-[color:var(--color-text-strong)]">Juan Pablo Pinilla</p>
                </div>
                <p class="hero-photo__caption-copy">
                  <span class="lang-es">Desarrollo software util, ordenado y listo para operar en contextos reales.</span>
                  <span class="lang-en">I build useful, structured software that is ready for real operational contexts.</span>
                </p>
              </figcaption>
            </figure>

            <div class="hero-side-grid">
              <article data-motion-reveal class="console-card panel rounded-[1.75rem] p-5">
                <div class="mb-5 flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-rose-300/80"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-amber-200/80"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-cyan-300/80"></span>
                </div>
                <p class="font-mono text-xs uppercase tracking-[0.28em] text-[color:var(--color-text-soft)]">
                  <span class="lang-es">Inicializando secuencia profesional...</span>
                  <span class="lang-en">Initializing professional sequence...</span>
                </p>
                <div class="mt-5 space-y-3 font-mono text-sm text-[color:var(--color-text-soft)]">
                  <p><span class="text-[color:var(--color-accent)]">const engineer</span> = {'{'}</p>
                  <p class="pl-4">name: <span class="text-[color:var(--color-text-strong)]">"Juan Pablo Pinilla"</span>,</p>
                  <p class="pl-4">focus: <span class="text-[color:var(--color-text-strong)]">"Product + Systems"</span>,</p>
                  <p class="pl-4">stack: <span class="text-[color:var(--color-text-strong)]">["C#", "JavaScript", "SQL"]</span>,</p>
                  <p class="pl-4">mode: <span class="text-[color:var(--color-text-strong)]">"Build / Refine / Ship"</span></p>
                  <p>{'}'}</p>
                </div>
                <div class="mt-6">
                  <div class="h-1.5 rounded-full bg-[color:var(--color-control-hover)]">
                    <div class="h-1.5 w-[84%] rounded-full bg-gradient-to-r from-[color:var(--color-accent)] to-[color:var(--color-highlight)]"></div>
                  </div>
                  <p class="mt-3 text-xs uppercase tracking-[0.22em] text-[color:var(--color-text-soft)]">
                    <span class="lang-es">cargando modulo visual...</span>
                    <span class="lang-en">loading visual module...</span>
                  </p>
                </div>
              </article>

              <article data-motion-reveal class="panel rounded-[1.75rem] p-5">
                <p class="eyebrow">signal trace</p>
                <p class="mt-3 text-xl font-semibold text-[color:var(--color-text-strong)]">
                  <span class="lang-es">Ingenieria orientada a sistemas legibles, utiles y mantenibles.</span>
                  <span class="lang-en">Engineering focused on readable, useful, and maintainable systems.</span>
                </p>
                <p class="mt-4 text-sm leading-7 text-[color:var(--color-text-soft)]">
                  <span class="lang-es">Combino backend, bases de datos y frontend para construir software que realmente soporte operaciones, equipos y decisiones.</span>
                  <span class="lang-en">I combine backend, databases, and frontend to build software that truly supports operations, teams, and decisions.</span>
                </p>
              </article>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-18">
    <div class="container-shell">
      <div class="section-header">
        <div>
          <p class="eyebrow">core competencies</p>
          <h2 class="display-title mt-3 text-4xl font-semibold uppercase sm:text-5xl">Engineering Stack</h2>
        </div>
        <p class="max-w-2xl text-sm leading-7 text-[color:var(--color-text-soft)] sm:text-base">
          <span class="lang-es">Un stack enfocado en resolver operaciones reales: automatizacion, modelado de datos, interfaces funcionales y colaboracion tecnica ordenada.</span>
          <span class="lang-en">A stack focused on solving real operations: automation, data modeling, functional interfaces, and organized technical collaboration.</span>
        </p>
      </div>

      <div data-motion-stagger class="stack-grid mt-8">
        {stackGrid.map((item) => (
          <article data-motion-reveal data-motion-hover class="stack-card panel rounded-[1.5rem] p-5">
            <span class="stack-card__icon">&lt;/&gt;</span>
            <h3 class="mt-6 text-lg font-semibold uppercase tracking-[0.18em] text-[color:var(--color-text-strong)]">{item.label}</h3>
            <p class="mt-3 text-sm leading-7 text-[color:var(--color-text-soft)]">
              <span class="lang-es">{item.detailEs}</span>
              <span class="lang-en">{item.detailEn}</span>
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-10 sm:py-14">
    <div class="container-shell">
      <div class="section-header">
        <div>
          <p class="eyebrow">deployed solutions</p>
          <h2 class="display-title mt-3 text-4xl font-semibold uppercase sm:text-5xl">Selected Projects</h2>
        </div>
        <p class="max-w-2xl text-sm leading-7 text-[color:var(--color-text-soft)] sm:text-base">
          <span class="lang-es">Proyectos donde participe en modelado, logica, integracion y estructura operativa para problemas concretos.</span>
          <span class="lang-en">Projects where I contributed to modeling, logic, integration, and operational structure for concrete problems.</span>
        </p>
      </div>

      <div data-motion-stagger class="project-grid mt-8">
        {featuredProjects.map((project, index) => (
          <article data-motion-reveal data-motion-hover class="group project-card panel overflow-hidden rounded-[1.8rem]">
            <div class="project-card__visual">
              {project.data.cover && (
                <img
                  src={project.data.cover}
                  alt={`${project.data.title} concept art`}
                  loading="lazy"
                  class="h-full w-full object-cover opacity-90 transition duration-500 group-hover:scale-[1.02]"
                />
              )}
              <div class="project-card__overlay"></div>
            </div>

            <div class="p-6 sm:p-7">
              <div class="flex items-center justify-between gap-4">
                <div class="flex flex-wrap gap-2">
                  {project.data.technologies.slice(0, 3).map((tech) => (
                    <span class="rounded-full border border-[color:var(--color-tag-border)] bg-[color:var(--color-tag-bg)] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-[color:var(--color-accent)]">{tech}</span>
                  ))}
                </div>
                <span class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-text-soft)]">
                  {project.data.year}
                </span>
              </div>

              <h3 class="mt-5 text-2xl font-semibold uppercase tracking-tight text-[color:var(--color-text-strong)] sm:text-3xl">
                <span class="lang-es">{project.data.title}</span>
                <span class="lang-en">{project.data.titleEn ?? project.data.title}</span>
              </h3>

              <p class="mt-4 text-sm leading-7 text-[color:var(--color-text-soft)] sm:text-base">
                <span class="lang-es">{project.data.summary}</span>
                <span class="lang-en">{project.data.summaryEn ?? project.data.summary}</span>
              </p>

              <div class="project-log mt-5 rounded-[1.2rem] border border-[color:var(--color-border)] p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-accent)]">
                  <span class="lang-es">registro operativo {index + 1}</span>
                  <span class="lang-en">operation log {index + 1}</span>
                </p>
                <p class="mt-3 text-sm leading-7 text-[color:var(--color-text-soft)]">
                  <span class="lang-es">{project.data.result}</span>
                  <span class="lang-en">{project.data.resultEn ?? project.data.result}</span>
                </p>
              </div>

              <div class="mt-6 flex flex-wrap gap-3">
                {project.data.repoUrl && (
                  <a href={project.data.repoUrl} target="_blank" rel="noreferrer" class="btn-secondary">
                    GitHub
                  </a>
                )}
                <a href="/projects" class="btn-secondary">
                  <span class="lang-es">Ver detalle</span>
                  <span class="lang-en">View detail</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-8 sm:py-12">
    <div class="container-shell">
      <div data-motion-stagger class="metrics-strip panel cut-corner rounded-[2rem] px-6 py-8 sm:px-10">
        {proofMetrics.map((metric) => (
          <article data-motion-reveal class="metric-item">
            <p class="text-4xl font-semibold tracking-[-0.06em] text-[color:var(--color-accent)] sm:text-5xl">{metric.value}</p>
            <p class="mt-2 text-xs font-semibold uppercase tracking-[0.24em] text-[color:var(--color-text-soft)]">
              <span class="lang-es">{metric.labelEs}</span>
              <span class="lang-en">{metric.labelEn}</span>
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-18">
    <div class="container-shell">
      <div class="section-header">
        <div>
          <p class="eyebrow">build protocol</p>
          <h2 class="display-title mt-3 text-4xl font-semibold uppercase sm:text-5xl">How I Work</h2>
        </div>
        <p class="max-w-2xl text-sm leading-7 text-[color:var(--color-text-soft)] sm:text-base">
          <span class="lang-es">Mi forma de trabajo prioriza estructura, comunicacion y trazabilidad para que las soluciones no solo funcionen, sino que se puedan operar y mejorar.</span>
          <span class="lang-en">My workflow prioritizes structure, communication, and traceability so solutions not only work, but can be operated and improved.</span>
        </p>
      </div>

      <div data-motion-stagger class="mt-8 grid gap-5 lg:grid-cols-3">
        {operatingModes.map((mode) => (
          <article data-motion-reveal data-motion-hover class="panel rounded-[1.6rem] p-6">
            <span class="inline-flex rounded-full border border-[color:var(--color-tag-border)] bg-[color:var(--color-tag-bg)] px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--color-accent)]">
              {mode.id}
            </span>
            <h3 class="mt-5 text-2xl font-semibold text-[color:var(--color-text-strong)]">
              <span class="lang-es">{mode.titleEs}</span>
              <span class="lang-en">{mode.titleEn}</span>
            </h3>
            <p class="mt-4 text-sm leading-7 text-[color:var(--color-text-soft)]">
              <span class="lang-es">{mode.copyEs}</span>
              <span class="lang-en">{mode.copyEn}</span>
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="container-shell">
      <div data-motion-reveal class="cta-shell panel cut-corner rounded-[2.2rem] px-6 py-14 text-center sm:px-10">
        <p class="eyebrow justify-center">ready to build</p>
        <h2 class="display-title mx-auto mt-5 max-w-4xl text-balance text-4xl font-semibold uppercase leading-[0.95] sm:text-6xl">
          <span class="lang-es">Listo para construir productos y sistemas con criterio tecnico.</span>
          <span class="lang-en">Ready to build products and systems with strong technical judgment.</span>
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-[color:var(--color-text-soft)] sm:text-base">
          <span class="lang-es">Disponible para colaborar en retos de software, operaciones internas, plataformas web o soluciones que necesiten orden, mantenimiento y ejecucion real.</span>
          <span class="lang-en">Available to collaborate on software challenges, internal operations, web platforms, or solutions that need order, maintainability, and real execution.</span>
        </p>
        <div data-motion-stagger class="mt-8 flex flex-wrap justify-center gap-3">
          <a data-motion-hover href="/contact" class="btn-primary">
            <span class="lang-es">Inicializar contacto</span>
            <span class="lang-en">Initialize contact</span>
          </a>
          <a data-motion-hover href={siteConfig.github} target="_blank" rel="noreferrer" class="btn-secondary">
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .hero-shell {
    position: relative;
  }

  .hero-shell::before {
    content: '';
    position: absolute;
    inset: 2.5rem 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-strong), transparent);
  }

  .hero-grid {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 2rem;
    min-height: min(54rem, 88vh);
  }

  .hero-grid::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 18%, var(--color-radial-1), transparent 26%),
      radial-gradient(circle at 82% 24%, var(--color-radial-2), transparent 20%),
      linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.03));
    pointer-events: none;
  }

  .hero-copy,
  .hero-media {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    align-self: center;
  }

  .hero-accent {
    color: transparent;
    background: linear-gradient(180deg, var(--color-accent), var(--color-accent-soft));
    -webkit-background-clip: text;
    background-clip: text;
    text-shadow: 0 0 28px color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero-media,
  .hero-side-grid {
    display: grid;
    gap: 1rem;
  }

  .hero-photo {
    overflow: hidden;
  }

  .hero-photo__frame {
    position: relative;
    overflow: hidden;
    border-radius: 1.4rem;
    border: 1px solid var(--color-border);
    background:
      radial-gradient(circle at 20% 20%, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 22%),
      linear-gradient(180deg, var(--color-surface-strong), var(--color-surface-muted));
    aspect-ratio: 0.82;
  }

  .hero-photo__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 14%;
    display: block;
  }

  .hero-photo__wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 55%, color-mix(in srgb, var(--color-bg) 12%, transparent) 100%),
      radial-gradient(circle at 50% 100%, color-mix(in srgb, var(--color-accent) 14%, transparent), transparent 38%);
    pointer-events: none;
  }

  .hero-photo__caption {
    display: grid;
    gap: 0.9rem;
    padding: 1rem 0.35rem 0.1rem;
  }

  .hero-photo__caption-copy {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text-soft);
  }

  .console-card {
    position: relative;
    overflow: hidden;
  }

  .console-card::after {
    content: '';
    position: absolute;
    inset: auto 1.5rem 1.5rem;
    height: 1px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--color-accent) 10%, transparent), var(--color-accent), transparent);
  }

  .section-header {
    display: grid;
    gap: 1rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .stack-grid,
  .project-grid {
    display: grid;
    gap: 1.25rem;
  }

  .stack-card {
    position: relative;
    min-height: 16rem;
  }

  .stack-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    border: 1px solid var(--color-tag-border);
    background: var(--color-tag-bg);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .project-card {
    position: relative;
  }

  .project-card__visual {
    position: relative;
    height: 18rem;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background:
      radial-gradient(circle at 30% 30%, color-mix(in srgb, var(--color-text-strong) 12%, transparent), transparent 18%),
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 20%, transparent), transparent 40%),
      linear-gradient(135deg, var(--color-surface-strong), var(--color-surface-muted));
  }

  .project-card__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 0%, color-mix(in srgb, var(--color-bg) 36%, transparent) 100%),
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 14%, transparent), transparent 38%);
  }

  .project-log {
    background: color-mix(in srgb, var(--color-surface-muted) 82%, transparent);
  }

  .metrics-strip {
    display: grid;
    gap: 1.5rem;
  }

  .metric-item {
    text-align: center;
  }

  .cta-shell {
    position: relative;
    overflow: hidden;
  }

  .cta-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--color-accent) 18%, transparent), transparent 30%),
      linear-gradient(180deg, transparent, color-mix(in srgb, var(--color-text-strong) 3%, transparent));
    pointer-events: none;
  }

  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.06fr) minmax(360px, 0.94fr);
      align-items: center;
    }

    .hero-media {
      align-self: stretch;
    }

    .hero-side-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .section-header {
      grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1fr);
      align-items: end;
    }

    .stack-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .metrics-strip {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 639px) {
    .hero-actions {
      flex-direction: column;
    }
  }
</style>
