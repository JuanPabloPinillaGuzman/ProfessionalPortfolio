---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../ui/layout/Section.astro';
import { siteConfig } from '../config/site';
---
<MainLayout
  title="Contact"
  description={siteConfig.description}
  canonicalPath="/contact"
>
  <Section
    titleEs="Construyamos algo util"
    titleEn="Let's build something useful"
    subtitleEs="Comparte el contexto del rol o proyecto y te respondere por canales profesionales."
    subtitleEn="Share the role or project context and I will get back through professional channels."
    className=""
  >
    <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
      <form id="contact-form" data-motion-reveal class="panel cut-corner rounded-3xl p-6" aria-label="Contact form">
        <label for="contact-name" class="mb-2 block text-sm font-semibold text-[color:var(--color-text)]">
          <span class="lang-es">Nombre</span>
          <span class="lang-en">Name</span>
        </label>
        <input id="contact-name" name="name" type="text" required class="mb-4 w-full rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-4 py-3 text-[color:var(--color-text)]" />

        <label for="contact-company" class="mb-2 block text-sm font-semibold text-[color:var(--color-text)]">
          <span class="lang-es">Empresa</span>
          <span class="lang-en">Company</span>
        </label>
        <input id="contact-company" name="company" type="text" class="mb-4 w-full rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-4 py-3 text-[color:var(--color-text)]" />

        <label for="contact-message" class="mb-2 block text-sm font-semibold text-[color:var(--color-text)]">
          <span class="lang-es">Mensaje</span>
          <span class="lang-en">Message</span>
        </label>
        <textarea id="contact-message" name="message" rows="6" required class="mb-4 w-full rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-4 py-3 text-[color:var(--color-text)]"></textarea>

        <button data-motion-hover type="submit" class="rounded-full bg-[color:var(--color-accent)] px-6 py-3 font-semibold text-white transition hover:bg-[color:var(--color-accent-soft)]">
          <span class="lang-es">Redactar correo</span>
          <span class="lang-en">Compose email</span>
        </button>
        <p class="mt-3 text-sm text-[color:var(--color-text-soft)]">
          <span class="lang-es">Este formulario abre tu app de correo local y evita publicar una direccion de correo en texto plano.</span>
          <span class="lang-en">This form opens your local email app and avoids publishing a plain-text email address on the page.</span>
        </p>
      </form>

      <aside data-motion-reveal data-motion-hover class="panel panel-hover space-y-4 rounded-3xl p-6">
        <h2 class="text-xl font-bold text-[color:var(--color-text)]">
          <span class="lang-es">Enlaces profesionales</span>
          <span class="lang-en">Professional links</span>
        </h2>
        <p class="text-[color:var(--color-text-soft)]">
          <span class="lang-es">Para mayor contexto, incluye rol, tiempo estimado y alcance del proyecto.</span>
          <span class="lang-en">For faster context, include role title, timeline, and project scope.</span>
        </p>
        <a data-motion-hover href={siteConfig.linkedin} target="_blank" rel="noreferrer" class="block rounded-xl border border-[color:var(--color-border)] px-4 py-3 font-semibold text-[color:var(--color-text)] transition hover:border-[color:var(--color-accent-soft)] hover:text-[color:var(--color-accent)]">
          LinkedIn
        </a>
        <a data-motion-hover href={siteConfig.github} target="_blank" rel="noreferrer" class="block rounded-xl border border-[color:var(--color-border)] px-4 py-3 font-semibold text-[color:var(--color-text)] transition hover:border-[color:var(--color-accent-soft)] hover:text-[color:var(--color-accent)]">
          GitHub
        </a>
      </aside>
    </div>
  </Section>
</MainLayout>

<script>
  const form = document.querySelector('#contact-form');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const target = event.currentTarget;
    if (!(target instanceof HTMLFormElement)) return;

    const name = target.elements.namedItem('name');
    const company = target.elements.namedItem('company');
    const message = target.elements.namedItem('message');

    if (!(name instanceof HTMLInputElement)) return;
    if (!(company instanceof HTMLInputElement)) return;
    if (!(message instanceof HTMLTextAreaElement)) return;

    const mailbox = ['contact', 'juanpablopinilla.dev'];
    const lang = document.documentElement.dataset.lang === 'en' ? 'en' : 'es';
    const subjectPrefix = lang === 'en' ? 'Portfolio inquiry from' : 'Consulta de portafolio de';
    const labelName = lang === 'en' ? 'Name' : 'Nombre';
    const labelCompany = lang === 'en' ? 'Company' : 'Empresa';
    const emptyCompany = lang === 'en' ? 'N/A' : 'No aplica';

    const subject = encodeURIComponent(`${subjectPrefix} ${name.value.trim() || 'recruiter'}`);
    const body = encodeURIComponent([
      `${labelName}: ${name.value.trim()}`,
      `${labelCompany}: ${company.value.trim() || emptyCompany}`,
      '',
      message.value.trim()
    ].join('\n'));

    window.location.href = `mailto:${mailbox[0]}@${mailbox[1]}?subject=${subject}&body=${body}`;
  });
</script>
