---
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/', labelEs: 'Inicio', labelEn: 'Home' },
  { href: '/about', labelEs: 'Sobre mi', labelEn: 'About' },
  { href: '/projects', labelEs: 'Proyectos', labelEn: 'Projects' },
  { href: '/contact', labelEs: 'Contacto', labelEn: 'Contact' }
];

const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-20 border-b border-[color:var(--color-border)] bg-[color:var(--color-header-bg)] backdrop-blur-xl">
  <div class="container-shell">
    <div class="header-shell">
      <a href="/" class="group header-brand inline-flex items-center rounded-xl text-sm font-semibold text-[color:var(--color-text)]">
        <span class="brand-mark" aria-hidden="true">
          <span class="brand-mark__j">J</span>
          <span class="brand-mark__p">P</span>
        </span>
        <span class="brand-copy">
          <span class="lang-es">Portafolio Profesional</span>
          <span class="lang-en">Professional Portfolio</span>
        </span>
      </a>

      <nav aria-label="Main navigation" class="header-nav text-[11px] font-semibold uppercase tracking-[0.22em]">
        {links.map((link) => {
          const isActive =
            currentPath === link.href ||
            (link.href !== '/' && currentPath.startsWith(`${link.href}/`));

          return (
            <a
              href={link.href}
              class:list={[
                'nav-pill',
                isActive && 'nav-pill--active'
              ]}
            >
              <span class="lang-es">{link.labelEs}</span>
              <span class="lang-en">{link.labelEn}</span>
            </a>
          );
        })}
      </nav>

      <div class="header-actions">
        <ThemeToggle />
        <LanguageToggle />
        <a href="/contact" class="btn-secondary header-cta">
          <span class="lang-es">Contacto</span>
          <span class="lang-en">Contact</span>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header-shell {
    display: grid;
    gap: 0.6rem;
    padding: 0.65rem 0;
  }

  .header-brand {
    min-height: 2rem;
    gap: 0.82rem;
  }

  .brand-mark {
    position: relative;
    display: inline-flex;
    width: 2.8rem;
    height: 2.2rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    overflow: visible;
  }

  .brand-mark__j,
  .brand-mark__p {
    position: absolute;
    font-family: var(--font-signature);
    font-size: 3.35rem;
    font-style: italic;
    font-weight: 700;
    line-height: 0.75;
    letter-spacing: 0;
    text-transform: none;
    transition: color 180ms ease, transform 180ms ease;
  }

  .brand-mark__j {
    left: -0.28rem;
    top: 0.62rem;
    transform: rotate(-10deg);
  }

  .brand-mark__p {
    left: 0.82rem;
    top: -0.32rem;
    transform: rotate(3deg);
  }

  .group:hover .brand-mark__j,
  .group:hover .brand-mark__p {
    color: var(--color-highlight);
  }

  .brand-copy {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.28em;
  }

  .header-nav,
  .header-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .header-nav {
    justify-content: flex-start;
  }

  .header-cta {
    display: none;
  }

  @media (min-width: 900px) {
    .header-shell {
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 1rem;
      padding: 0.7rem 0;
    }

    .header-nav {
      justify-content: center;
      min-width: 0;
    }

    .header-actions {
      justify-content: flex-end;
      flex-wrap: nowrap;
    }

    .header-cta {
      display: inline-flex;
      width: auto;
      padding-inline: 1rem;
    }
  }
</style>
