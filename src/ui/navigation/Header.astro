---
import LanguageToggle from './LanguageToggle.astro';

const links = [
  { href: '/', labelEs: 'Inicio', labelEn: 'Home' },
  { href: '/about', labelEs: 'Sobre mi', labelEn: 'About' },
  { href: '/projects', labelEs: 'Proyectos', labelEn: 'Projects' },
  { href: '/contact', labelEs: 'Contacto', labelEn: 'Contact' }
];

const currentPath = Astro.url.pathname;
---
<header data-motion="header" class="sticky top-0 z-20 border-b border-[color:var(--color-border)] bg-[rgba(6,9,15,0.82)] backdrop-blur-xl">
  <div class="container-shell py-4">
    <div class="surface-glass cut-corner flex flex-col gap-3 rounded-[1.6rem] px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-5">
      <a href="/" class="group inline-flex items-center gap-3 rounded-xl px-1 py-1 text-sm font-semibold uppercase tracking-[0.3em] text-[color:var(--color-text)]">
        <span class="text-[color:var(--color-accent)] transition group-hover:text-[color:var(--color-highlight)]">Portafolio Profesional</span>
      </a>

      <div class="flex flex-wrap items-center gap-3">
        <nav aria-label="Main navigation" data-motion-stagger class="flex flex-wrap items-center gap-1 text-xs font-semibold uppercase tracking-[0.22em]">
          {links.map((link) => {
            const isActive =
              currentPath === link.href ||
              (link.href !== '/' && currentPath.startsWith(`${link.href}/`));

            return (
              <a
                href={link.href}
                data-motion-hover
                class:list={[
                  'rounded-full border px-4 py-2 transition',
                  isActive
                    ? 'border-cyan-300/40 bg-cyan-300/10 text-[color:var(--color-accent)]'
                    : 'border-transparent text-[color:var(--color-text-soft)] hover:border-[color:var(--color-border)] hover:text-[color:var(--color-text)]'
                ]}
              >
                <span class="lang-es">{link.labelEs}</span>
                <span class="lang-en">{link.labelEn}</span>
              </a>
            );
          })}
        </nav>

        <a
          data-motion-hover
          href="/contact"
          class="rounded-full border border-cyan-300/35 bg-cyan-300/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-[color:var(--color-accent)] transition hover:border-cyan-200/60 hover:bg-cyan-300/16"
        >
          <span class="lang-es">Contacto</span>
          <span class="lang-en">Contact</span>
        </a>

        <div class="shrink-0">
          <LanguageToggle />
        </div>
      </div>
    </div>
  </div>
</header>
