---
interface Props {
  href: string;
  labelEs: string;
  labelEn: string;
}

const { href, labelEs, labelEn } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive =
  currentPath === href || (href !== '/' && currentPath.startsWith(`${href}/`));
---
<a
  href={href}
  data-motion-hover
  class:list={[
    'rounded-full px-4 py-2 text-sm font-semibold transition duration-200',
    isActive
      ? 'bg-[color:var(--color-accent)] text-white shadow-md shadow-orange-200/70'
      : 'text-[color:var(--color-text-soft)] hover:bg-[color:var(--color-surface-muted)] hover:text-[color:var(--color-text)]'
  ]}
>
  <span class="lang-es">{labelEs}</span>
  <span class="lang-en">{labelEn}</span>
</a>
