<div class="control-cluster text-xs font-bold uppercase tracking-[0.18em]" aria-label="Language selector">
  <button
    type="button"
    data-lang-btn="es"
    data-active="false"
    class="control-button px-3 py-2"
    aria-pressed="false"
  >
    ES
  </button>
  <button
    type="button"
    data-lang-btn="en"
    data-active="false"
    class="control-button px-3 py-2"
    aria-pressed="false"
  >
    EN
  </button>
</div>

<script>
  const LANG_KEY = 'portfolio-lang';

  const applyLanguage = (lang) => {
    const safeLang = lang === 'en' ? 'en' : 'es';
    document.documentElement.dataset.lang = safeLang;
    document.documentElement.lang = safeLang;

    document.querySelectorAll('[data-lang-btn]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const active = button.dataset.langBtn === safeLang;
      button.dataset.active = active ? 'true' : 'false';
      button.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
  };

  const initial = localStorage.getItem(LANG_KEY) ?? 'en';
  applyLanguage(initial);

  document.querySelectorAll('[data-lang-btn]').forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    button.addEventListener('click', () => {
      const selected = button.dataset.langBtn === 'en' ? 'en' : 'es';
      localStorage.setItem(LANG_KEY, selected);
      applyLanguage(selected);
    });
  });
</script>
