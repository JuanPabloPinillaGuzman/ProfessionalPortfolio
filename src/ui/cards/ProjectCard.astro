---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---
<article data-motion-reveal data-motion-hover class="group panel panel-hover relative overflow-hidden rounded-3xl p-6">
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[color:var(--color-accent)] via-[color:var(--color-accent-soft)] to-[color:var(--color-highlight)]"></div>
  <div class="absolute -right-7 -top-7 h-16 w-16 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)]/80"></div>
  {project.data.cover && (
    <div class="mb-5 overflow-hidden rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)]">
      <img
        src={project.data.cover}
        alt={`${project.data.title} visual concept`}
        loading="lazy"
        class="h-40 w-full object-cover transition duration-500 group-hover:scale-[1.02]"
      />
    </div>
  )}
  <p class="eyebrow">{project.data.year}</p>
  <h3 class="mt-2 text-balance text-2xl font-bold text-[color:var(--color-text)]">
    <span class="lang-es">{project.data.title}</span>
    <span class="lang-en">{project.data.titleEn ?? project.data.title}</span>
  </h3>
  <p class="mt-3 text-[color:var(--color-text-soft)]">
    <span class="lang-es">{project.data.summary}</span>
    <span class="lang-en">{project.data.summaryEn ?? project.data.summary}</span>
  </p>

  <dl class="mt-6 space-y-4 text-sm leading-relaxed">
    <div>
      <dt class="font-bold text-[color:var(--color-text)]">
        <span class="lang-es">Problema</span>
        <span class="lang-en">Problem</span>
      </dt>
      <dd class="text-[color:var(--color-text-soft)]">
        <span class="lang-es">{project.data.problem}</span>
        <span class="lang-en">{project.data.problemEn ?? project.data.problem}</span>
      </dd>
    </div>
    <div>
      <dt class="font-bold text-[color:var(--color-text)]">
        <span class="lang-es">Solucion</span>
        <span class="lang-en">Solution</span>
      </dt>
      <dd class="text-[color:var(--color-text-soft)]">
        <span class="lang-es">{project.data.solution}</span>
        <span class="lang-en">{project.data.solutionEn ?? project.data.solution}</span>
      </dd>
    </div>
    <div>
      <dt class="font-bold text-[color:var(--color-text)]">
        <span class="lang-es">Resultado</span>
        <span class="lang-en">Result</span>
      </dt>
      <dd class="text-[color:var(--color-text-soft)]">
        <span class="lang-es">{project.data.result}</span>
        <span class="lang-en">{project.data.resultEn ?? project.data.result}</span>
      </dd>
    </div>
  </dl>

  <ul class="mt-6 flex flex-wrap gap-2">
    {project.data.technologies.map((tech) => (
      <li class="rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)] px-3 py-1 text-xs font-semibold text-[color:var(--color-accent)]">{tech}</li>
    ))}
  </ul>

  <div class="mt-6 flex flex-wrap gap-3 text-sm font-semibold">
    {project.data.liveUrl && (
      <a href={project.data.liveUrl} target="_blank" rel="noreferrer" class="rounded-full border border-[color:var(--color-border)] px-4 py-2 hover:border-[color:var(--color-accent-soft)] hover:text-[color:var(--color-accent)]">
        <span class="lang-es">Demo</span>
        <span class="lang-en">Live Demo</span>
      </a>
    )}
    {project.data.repoUrl && (
      <a href={project.data.repoUrl} target="_blank" rel="noreferrer" class="rounded-full border border-[color:var(--color-border)] px-4 py-2 hover:border-[color:var(--color-accent-soft)] hover:text-[color:var(--color-accent)]">
        <span class="lang-es">Repositorio</span>
        <span class="lang-en">Repository</span>
      </a>
    )}
  </div>
</article>
