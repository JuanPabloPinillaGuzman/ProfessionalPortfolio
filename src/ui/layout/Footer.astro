---
import { siteConfig } from '../../config/site';
---
<footer data-motion-reveal class="mt-6 border-t border-[color:var(--color-border)]/85 bg-[color:var(--color-surface)]/75 backdrop-blur">
  <div class="container-shell flex flex-col gap-4 py-8 text-sm text-[color:var(--color-text-soft)] sm:flex-row sm:items-center sm:justify-between">
    <p>
      <span class="lang-es">© {new Date().getFullYear()} {siteConfig.shortName}. Hecho con Astro.</span>
      <span class="lang-en">© {new Date().getFullYear()} {siteConfig.shortName}. Built with Astro.</span>
    </p>
    <div class="flex items-center gap-4">
      <a href={siteConfig.github} target="_blank" rel="noreferrer" class="font-semibold hover:text-[color:var(--color-accent)]">GitHub</a>
      <a href={siteConfig.linkedin} target="_blank" rel="noreferrer" class="font-semibold hover:text-[color:var(--color-accent)]">LinkedIn</a>
    </div>
  </div>
</footer>
