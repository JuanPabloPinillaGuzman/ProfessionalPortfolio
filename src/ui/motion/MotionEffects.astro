<script>
  import { animate, hover, inView, stagger } from 'motion';

  const shouldReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!shouldReduceMotion) {
    animate('[data-motion="header"]', { opacity: [0, 1], y: [-20, 0] }, { duration: 0.5, easing: 'ease-out' });

    const heroTitle = document.querySelector('[data-motion="hero-title"]');
    if (heroTitle) {
      animate(heroTitle, { opacity: [0, 1], y: [30, 0] }, { duration: 0.65, easing: 'ease-out' });
    }

    const heroCopy = document.querySelector('[data-motion="hero-copy"]');
    if (heroCopy) {
      animate(heroCopy, { opacity: [0, 1], y: [24, 0] }, { duration: 0.6, delay: 0.08, easing: 'ease-out' });
    }

    document.querySelectorAll('[data-motion-stagger]').forEach((group) => {
      const children = Array.from(group.children);
      if (!children.length) return;

      animate(
        children,
        { opacity: [0, 1], y: [16, 0] },
        { duration: 0.5, delay: stagger(0.07), easing: 'ease-out' }
      );
    });

    inView(
      '[data-motion-reveal]',
      (element) => {
        if (element instanceof HTMLElement && element.dataset.motionDone === 'true') return;
        if (element instanceof HTMLElement) element.dataset.motionDone = 'true';

        animate(
          element,
          { opacity: [0, 1], y: [22, 0], filter: ['blur(3px)', 'blur(0px)'] },
          { duration: 0.52, easing: 'ease-out' }
        );
      },
      { margin: '0px 0px -12% 0px' }
    );

    document.querySelectorAll('[data-motion-hover]').forEach((element) => {
      hover(element, () => {
        animate(element, { y: -4, scale: 1.012 }, { duration: 0.2, easing: 'ease-out' });
        return () => animate(element, { y: 0, scale: 1 }, { duration: 0.2, easing: 'ease-out' });
      });
    });

    document.querySelectorAll('[data-motion-float]').forEach((element, index) => {
      const distance = index % 2 === 0 ? 12 : 18;
      const duration = 3.6 + (index % 3) * 0.8;

      animate(
        element,
        {
          y: [-distance, distance, -distance],
          x: [0, index % 2 === 0 ? 6 : -6, 0],
          rotate: [0, index % 2 === 0 ? 4 : -4, 0]
        },
        {
          duration,
          repeat: Infinity,
          easing: 'ease-in-out'
        }
      );
    });
  }
</script>
