<script>
  import { animate, hover, inView, stagger } from 'motion';

  const shouldReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!shouldReduceMotion) {
    const heroTitle = document.querySelector('[data-motion="hero-title"]');
    if (heroTitle) {
      animate(heroTitle, { opacity: [0, 1], y: [24, 0] }, { duration: 0.55, easing: 'ease-out' });
    }

    const heroCopy = document.querySelector('[data-motion="hero-copy"]');
    if (heroCopy) {
      animate(heroCopy, { opacity: [0, 1], y: [18, 0] }, { duration: 0.52, delay: 0.05, easing: 'ease-out' });
    }

    const heroMedia = document.querySelector('[data-motion="hero-media"]');
    if (heroMedia) {
      animate(heroMedia, { opacity: [0, 1], scale: [0.975, 1], y: [20, 0] }, { duration: 0.56, delay: 0.1, easing: 'ease-out' });
    }

    document.querySelectorAll('[data-motion-stagger]').forEach((group) => {
      const children = Array.from(group.children);
      if (!children.length) return;

      children.forEach((child) => {
        if (child instanceof HTMLElement) child.dataset.motionDone = 'true';
      });

      animate(
        children,
        { opacity: [0, 1], y: [12, 0] },
        { duration: 0.45, delay: stagger(0.05), easing: 'ease-out' }
      );
    });

    inView(
      '[data-motion-reveal]',
      (element) => {
        if (element instanceof HTMLElement && element.dataset.motionDone === 'true') return;
        if (element instanceof HTMLElement) element.dataset.motionDone = 'true';

        animate(
          element,
          { opacity: [0, 1], y: [16, 0], filter: ['blur(2px)', 'blur(0px)'] },
          { duration: 0.44, easing: 'ease-out' }
        );
      },
      { margin: '0px 0px -12% 0px' }
    );

    document.querySelectorAll('[data-motion-hover]').forEach((element) => {
      hover(element, () => {
        animate(element, { y: -2, scale: 1.006 }, { duration: 0.16, easing: 'ease-out' });
        return () => animate(element, { y: 0, scale: 1 }, { duration: 0.16, easing: 'ease-out' });
      });
    });

    document.querySelectorAll('[data-motion-float]').forEach((element, index) => {
      const distance = index % 2 === 0 ? 12 : 18;
      const duration = 3.6 + (index % 3) * 0.8;

      animate(
        element,
        {
          y: [-distance, distance, -distance],
          x: [0, index % 2 === 0 ? 6 : -6, 0],
          rotate: [0, index % 2 === 0 ? 4 : -4, 0]
        },
        {
          duration,
          repeat: Infinity,
          easing: 'ease-in-out'
        }
      );
    });
  }
</script>
