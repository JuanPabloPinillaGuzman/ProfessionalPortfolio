---
import '../styles/global.css';
import Header from '../ui/navigation/Header.astro';
import Footer from '../ui/layout/Footer.astro';
import MotionEffects from '../ui/motion/MotionEffects.astro';
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalPath = '/',
  ogType = 'website'
} = Astro.props;

const pageTitle = `${title} | ${siteConfig.shortName}`;
const canonicalUrl = new URL(canonicalPath, Astro.site);
---
<!doctype html>
<html lang="en" data-lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <script is:inline>
      (() => {
        const THEME_KEY = 'portfolio-theme';
        const root = document.documentElement;

        try {
          const storedTheme = localStorage.getItem(THEME_KEY);
          const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          const theme = storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : systemTheme;

          root.dataset.theme = theme;
          root.style.colorScheme = theme;
        } catch {
          root.dataset.theme = 'dark';
          root.style.colorScheme = 'dark';
        }
      })();
    </script>

    <title>{pageTitle}</title>
  </head>
  <body class="text-[color:var(--color-text)] antialiased">
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div data-motion-float class="absolute -left-16 top-10 h-72 w-72 rounded-full bg-[color:var(--color-orb-primary)] blur-3xl"></div>
      <div data-motion-float class="absolute right-[-6rem] top-44 h-80 w-80 rounded-full bg-[color:var(--color-orb-secondary)] blur-3xl"></div>
      <div data-motion-float class="absolute bottom-[-4rem] left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-[color:var(--color-orb-tertiary)] blur-3xl"></div>
      <div class="absolute inset-x-[6%] top-24 h-px bg-gradient-to-r from-transparent via-[color:var(--color-border-strong)] to-transparent"></div>
      <div class="absolute inset-y-[12%] right-[8%] w-px bg-gradient-to-b from-transparent via-[color:var(--color-border)] to-transparent"></div>
      <div data-motion-float class="absolute left-[10%] top-[22%] h-24 w-24 rounded-[1.75rem] border border-[color:var(--color-float-border)] bg-[color:var(--color-float-panel)] backdrop-blur-sm"></div>
      <div data-motion-float class="absolute bottom-[18%] right-[14%] h-20 w-20 rotate-12 border border-[color:var(--color-float-border)] bg-[color:var(--color-float-panel)]"></div>
    </div>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[color:var(--color-surface-muted)] focus:px-4 focus:py-2 focus:text-[color:var(--color-text)] focus:shadow-lg">
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="pb-10">
      <slot />
    </main>
    <Footer />
    <MotionEffects />
  </body>
</html>
