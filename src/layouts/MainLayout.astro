---
import '../styles/global.css';
import Header from '../ui/navigation/Header.astro';
import Footer from '../ui/layout/Footer.astro';
import MotionEffects from '../ui/motion/MotionEffects.astro';
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalPath = '/',
  ogType = 'website'
} = Astro.props;

const pageTitle = `${title} | ${siteConfig.shortName}`;
const canonicalUrl = new URL(canonicalPath, Astro.site);
---
<!doctype html>
<html lang="es" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <title>{pageTitle}</title>
  </head>
  <body class="text-[color:var(--color-text)] antialiased">
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div data-motion-float class="absolute -left-16 top-10 h-72 w-72 rounded-full bg-cyan-300/10 blur-3xl"></div>
      <div data-motion-float class="absolute right-[-6rem] top-44 h-80 w-80 rounded-full bg-sky-400/10 blur-3xl"></div>
      <div data-motion-float class="absolute bottom-[-4rem] left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-emerald-300/8 blur-3xl"></div>
      <div class="absolute inset-x-[6%] top-24 h-px bg-gradient-to-r from-transparent via-cyan-300/25 to-transparent"></div>
      <div class="absolute inset-y-[12%] right-[8%] w-px bg-gradient-to-b from-transparent via-cyan-300/15 to-transparent"></div>
      <div data-motion-float class="absolute left-[10%] top-[22%] h-24 w-24 rounded-[1.75rem] border border-cyan-200/10 bg-white/2 backdrop-blur-sm"></div>
      <div data-motion-float class="absolute bottom-[18%] right-[14%] h-20 w-20 rotate-12 border border-sky-200/12 bg-white/2"></div>
    </div>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[color:var(--color-surface-muted)] focus:px-4 focus:py-2 focus:text-[color:var(--color-text)] focus:shadow-lg">
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="pb-10">
      <slot />
    </main>
    <Footer />
    <MotionEffects />
  </body>
</html>
